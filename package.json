{
  "name": "hamzacoin-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Backend for the HamzaCoin Learn & Earn flow. Generates Wikipedia-article quizzes with Groq and signs EIP-712 score attestations the on-chain faucet can verify.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "express": "^4.19.2",
    "groq-sdk": "^0.7.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}

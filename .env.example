# Groq API key — get one at https://console.groq.com/keys
GROQ_API_KEY=

# Etherscan API key — free, get one at https://etherscan.io/myapikey
# Powers GET /api/holders, which reconstructs the all-time HMZ holder count
# from the full Transfer log. OPTIONAL: if unset, /api/holders returns 503 and
# the frontend falls back to its recent-block-window count. The backend still
# boots without it (quiz + verify are unaffected).
ETHERSCAN_API_KEY=

# Wallet whose signatures the HamzaFaucet contract trusts.
# This MUST match the TRUSTED_SIGNER_ADDRESS that was set when the faucet was deployed.
# 64 hex chars, with or without the 0x prefix. NEVER commit this value.
SIGNER_PRIVATE_KEY=

# The deployed HamzaFaucet contract address. Set this after running
#   npx hardhat run scripts/deploy-faucet.js --network sepolia
FAUCET_CONTRACT_ADDRESS=

# The HamzaCoin (HMZ) token address on Sepolia — usually does not change.
HMZ_CONTRACT_ADDRESS=0x619F30ec004442cdc3BE060FC927A3688054e6c3

# Chain ID. 11155111 = Sepolia testnet.
CHAIN_ID=11155111

# Port the API listens on.
PORT=3001
